echo "🔍 Running pre-push validation..."
echo ""

# Run type checking
echo "📘 Type checking..."
pnpm type-check || exit 1
echo "✅ Types valid"
echo ""

# Run linting
echo "🧹 Linting..."
pnpm lint || exit 1
echo "✅ Lint passed"
echo ""

# Run tests
echo "🧪 Running tests..."
pnpm test:run || exit 1
echo "✅ Tests passed"
echo ""

# Build Docker image (only if Docker is available)
if command -v docker >/dev/null 2>&1; then
  echo "🐳 Building Docker image..."
  pnpm docker:build || exit 1
  echo "✅ Docker build successful"
  echo ""
else
  echo "⚠️  Docker not found - skipping Docker build"
  echo "   Install Docker to enable full deployment validation"
  echo ""
fi

echo "🎉 All checks passed! Pushing..."
