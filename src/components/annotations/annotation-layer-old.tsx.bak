'use client'

import { useState, useEffect, useRef, useCallback } from 'react'
import { SimpleCanvas, type SimpleCanvasHandle, type DrawMode } from './simple-canvas'
import { AnnotationToolbar, type AnnotationMode } from './annotation-toolbar'
import {
  getPageAnnotations,
  savePageAnnotations,
  clearPageAnnotations,
  generateContentHash,
  checkVersionMismatch,
  type SectionAnnotation
} from '@/lib/indexeddb/annotations'

interface ContentSection {
  id: string
  headingText: string
  height: number
}

interface AnnotationLayerProps {
  pageId: string
  content: string
  children: React.ReactNode
}

export function AnnotationLayer({ pageId, content, children }: AnnotationLayerProps) {
  const [mode, setMode] = useState<AnnotationMode>('view')
  const [pageVersion, setPageVersion] = useState<string>('')
  const [versionMismatch, setVersionMismatch] = useState(false)
  const [hasAnnotations, setHasAnnotations] = useState(false)
  const [sections, setSections] = useState<ContentSection[]>([])
  const [sectionData, setSectionData] = useState<Map<string, string>>(new Map())
  const contentRef = useRef<HTMLDivElement>(null)
  const canvasRefs = useRef<Map<string, React.RefObject<SimpleCanvasHandle | null>>>(new Map())
  const saveTimeoutRef = useRef<NodeJS.Timeout | null>(null)

  // Fixed canvas width matching max-w-4xl (56rem = 896px at default font size)
  // Content is max-w-3xl (48rem = 768px)
  const CANVAS_WIDTH_REM = 56
  const CANVAS_WIDTH_PX = CANVAS_WIDTH_REM * 16 // 896px
  const CONTENT_WIDTH_REM = 48
  const MARGIN_EXTENSION_REM = (CANVAS_WIDTH_REM - CONTENT_WIDTH_REM) / 2 // 4rem on each side

  // Generate page version hash
  useEffect(() => {
    generateContentHash(content).then(hash => {
      setPageVersion(hash)
    })
  }, [content])

  // Check for version mismatch
  useEffect(() => {
    if (pageVersion && pageId) {
      checkVersionMismatch(pageId, pageVersion).then(mismatch => {
        setVersionMismatch(mismatch)
      })
    }
  }, [pageId, pageVersion])

  // Load annotations from IndexedDB
  useEffect(() => {
    if (!pageId) return

    getPageAnnotations(pageId).then(pageAnnotation => {
      if (pageAnnotation && pageAnnotation.sections.length > 0) {
        setHasAnnotations(true)
        const dataMap = new Map<string, string>()
        pageAnnotation.sections.forEach(section => {
          dataMap.set(section.sectionId, section.canvasData)
        })
        setSectionData(dataMap)
      }
    })
  }, [pageId])


  // Calculate section heights from DOM (positions handled by CSS)
  const calculateSections = useCallback(() => {
    if (!contentRef.current) {
      console.log('[AnnotationLayer] No contentRef')
      return
    }

    // First check if we have any headings at all
    const allHeadings = contentRef.current.querySelectorAll<HTMLElement>('h1, h2, h3, h4')
    console.log('[AnnotationLayer] Found total headings (h1-h4):', allHeadings.length)

    // Check which ones have data-section-id
    const headingsWithData = contentRef.current.querySelectorAll<HTMLElement>('[data-section-id]')
    console.log('[AnnotationLayer] Found headings with data-section-id:', headingsWithData.length)

    // Log first heading details
    if (allHeadings.length > 0) {
      const firstHeading = allHeadings[0]
      console.log('[AnnotationLayer] First heading details:', {
        tagName: firstHeading.tagName,
        text: firstHeading.textContent,
        hasSectionId: firstHeading.hasAttribute('data-section-id'),
        sectionId: firstHeading.getAttribute('data-section-id'),
        attributes: Array.from(firstHeading.attributes).map(a => ({ name: a.name, value: a.value }))
      })
    }

    const headings = headingsWithData
    const containerRect = contentRef.current.getBoundingClientRect()
    const newSections: ContentSection[] = []

    console.log('[AnnotationLayer] Calculating sections, found headings with data-section-id:', headings.length)

    headings.forEach((heading, index) => {
      const headingRect = heading.getBoundingClientRect()
      const nextHeading = headings[index + 1]

      // Calculate section height from this heading to the next
      let height: number

      if (nextHeading) {
        const nextRect = nextHeading.getBoundingClientRect()
        height = nextRect.top - headingRect.top
      } else {
        // Last section: extend to end of content
        const children = contentRef.current!.children
        if (children.length > 0) {
          const lastChild = children[children.length - 1]
          const lastChildRect = lastChild.getBoundingClientRect()
          height = lastChildRect.bottom - headingRect.top
        } else {
          height = containerRect.bottom - headingRect.top
        }
      }

      const sectionId = heading.getAttribute('data-section-id') || `section-${index}`
      const headingText = heading.getAttribute('data-heading-text') || heading.textContent || `section-${index}`

      newSections.push({
        id: sectionId,
        headingText,
        height: Math.ceil(Math.max(height, 50)) // Minimum 50px height
      })

      // Create canvas ref if it doesn't exist (use object with current property for mutability)
      if (!canvasRefs.current.has(sectionId)) {
        canvasRefs.current.set(sectionId, { current: null })
      }
    })

    console.log('[AnnotationLayer] Sections calculated:', newSections)
    setSections(newSections)
  }, [])

  // Parse content into sections by headings (once after content renders)
  useEffect(() => {
    if (!contentRef.current) return

    const timer = setTimeout(() => {
      calculateSections()
    }, 500) // Wait for markdown to render

    return () => clearTimeout(timer)
  }, [calculateSections])

  // Recalculate section heights on window resize
  // Note: Positions update automatically via SectionCanvas component
  useEffect(() => {
    let resizeTimeout: NodeJS.Timeout | null = null

    const handleResize = () => {
      // Clear existing timeout
      if (resizeTimeout) {
        clearTimeout(resizeTimeout)
      }

      // Debounce recalculation by 300ms - only recalculate after resize stops
      resizeTimeout = setTimeout(() => {
        console.log('[AnnotationLayer] Window resize stopped, recalculating heights')
        calculateSections()
      }, 300)
    }

    window.addEventListener('resize', handleResize)

    return () => {
      window.removeEventListener('resize', handleResize)
      if (resizeTimeout) {
        clearTimeout(resizeTimeout)
      }
    }
  }, [calculateSections])

  // Handle section annotation update with debounced save
  const handleSectionUpdate = useCallback((sectionId: string, data: string) => {
    // Update local state immediately
    setSectionData(prev => {
      const newMap = new Map(prev)
      newMap.set(sectionId, data)
      return newMap
    })

    // Check if there's actual data
    try {
      const paths = JSON.parse(data)
      const hasData = paths && paths.length > 0

      // Update hasAnnotations based on whether any section has data
      setSectionData(prev => {
        const hasAnyData = Array.from(prev.values()).some(d => {
          try {
            const p = JSON.parse(d)
            return p && p.length > 0
          } catch {
            return false
          }
        })
        setHasAnnotations(hasAnyData || hasData)
        return prev
      })

      if (!hasData) return
    } catch (error) {
      console.error('Error parsing canvas data:', error)
      return
    }

    // Clear existing timeout
    if (saveTimeoutRef.current) {
      clearTimeout(saveTimeoutRef.current)
    }

    // Debounce save by 2 seconds
    saveTimeoutRef.current = setTimeout(async () => {
      try {
        // Collect all section data
        const allSections: SectionAnnotation[] = []

        sections.forEach(section => {
          const data = sectionData.get(section.id)
          if (data) {
            try {
              const paths = JSON.parse(data)
              if (paths && paths.length > 0) {
                allSections.push({
                  sectionId: section.id,
                  headingText: section.headingText,
                  canvasData: data,
                  createdAt: Date.now(),
                  updatedAt: Date.now()
                })
              }
            } catch (error) {
              console.error('Error parsing section data:', error)
            }
          }
        })

        if (allSections.length > 0) {
          await savePageAnnotations(pageId, pageVersion, allSections)
          console.log('[AnnotationLayer] Saved', allSections.length, 'sections')
        }
      } catch (error) {
        console.error('Error saving annotations:', error)
      }
    }, 2000)
  }, [pageId, pageVersion, sections, sectionData])

  // Handle clear all annotations
  const handleClearAll = useCallback(async () => {
    try {
      await clearPageAnnotations(pageId)

      // Clear all canvases
      for (const [sectionId, canvasRef] of canvasRefs.current.entries()) {
        if (canvasRef.current) {
          canvasRef.current.clear()
        }
      }

      setSectionData(new Map())
      setHasAnnotations(false)
      setVersionMismatch(false)
    } catch (error) {
      console.error('Error clearing annotations:', error)
    }
  }, [pageId])

  return (
    <>
      {/* Version mismatch warning */}
      {versionMismatch && hasAnnotations && (
        <div className="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4 mb-6">
          <div className="flex items-start">
            <div className="flex-shrink-0">
              <svg className="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path fillRule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clipRule="evenodd" />
              </svg>
            </div>
            <div className="ml-3 flex-1">
              <p className="text-sm text-yellow-800 dark:text-yellow-200">
                <strong>Content Updated:</strong> This page has been modified. Your annotations may no longer align with the content.
              </p>
              <button
                onClick={handleClearAll}
                className="mt-2 text-sm text-yellow-800 dark:text-yellow-200 underline hover:no-underline"
              >
                Clear annotations and start fresh
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Content with section canvas overlays */}
      <div ref={contentRef} className="relative">
        {children}

        {/* Canvas overlays positioned via CSS relative to headings */}
        {sections.map(section => {
          const canvasRef = canvasRefs.current.get(section.id)
          if (!canvasRef) return null

          return (
            <SectionCanvas
              key={section.id}
              section={section}
              canvasRef={canvasRef}
              canvasWidth={CANVAS_WIDTH_PX}
              canvasWidthRem={CANVAS_WIDTH_REM}
              marginExtensionRem={MARGIN_EXTENSION_REM}
              mode={mode}
              onUpdate={(data) => handleSectionUpdate(section.id, data)}
              initialData={sectionData.get(section.id)}
            />
          )
        })}
      </div>

      {/* Toolbar */}
      <AnnotationToolbar
        mode={mode}
        onModeChange={setMode}
        onClear={handleClearAll}
        hasAnnotations={hasAnnotations}
      />
    </>
  )
}

// Component to render a canvas positioned relative to its heading
interface SectionCanvasProps {
  section: ContentSection
  canvasRef: React.RefObject<SimpleCanvasHandle | null>
  canvasWidth: number
  canvasWidthRem: number
  marginExtensionRem: number
  mode: AnnotationMode
  onUpdate: (data: string) => void
  initialData?: string
}

function SectionCanvas({
  section,
  canvasRef,
  canvasWidth,
  canvasWidthRem,
  marginExtensionRem,
  mode,
  onUpdate,
  initialData
}: SectionCanvasProps) {
  const containerRef = useRef<HTMLDivElement>(null)
  const [top, setTop] = useState(0)

  // Update position only when section changes (height or ID)
  useEffect(() => {
    if (!containerRef.current?.parentElement) {
      return
    }

    // Query for the heading element by data-section-id
    const headingElement = document.querySelector<HTMLElement>(`[data-section-id="${section.id}"]`)

    if (!headingElement) {
      console.log('[SectionCanvas] Heading not found:', section.id)
      return
    }

    const headingRect = headingElement.getBoundingClientRect()
    const containerRect = containerRef.current.parentElement.getBoundingClientRect()
    const newTop = headingRect.top - containerRect.top

    console.log('[SectionCanvas] updatePosition:', { sectionId: section.id, newTop, height: section.height })
    setTop(newTop)
  }, [section.height, section.id]) // Re-run when height or ID changes

  return (
    <div
      ref={containerRef}
      className="absolute left-0"
      style={{
        top: `${top}px`,
        marginLeft: `-${marginExtensionRem}rem`,
        width: `${canvasWidthRem}rem`,
        height: `${section.height}px`,
        pointerEvents: mode === 'view' ? 'none' : 'auto',
        zIndex: 10,
        boxShadow: mode !== 'view' ? '0 0 0 1px rgba(0,0,0,0.05)' : 'none'
      }}
    >
      <SimpleCanvas
        ref={canvasRef}
        width={canvasWidth}
        height={section.height}
        mode={mode === 'view' ? 'view' : (mode as DrawMode)}
        onUpdate={onUpdate}
        initialData={initialData}
      />
    </div>
  )
}
